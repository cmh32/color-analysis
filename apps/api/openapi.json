  "components": {
    "schemas": {
      "AnalysisResult": {
        "properties": {
          "session_id": {
            "type": "string",
            "title": "Session Id"
          },
          "top_2_seasons": {
            "prefixItems": [
              {
                "type": "string",
                "enum": [
                  "Spring",
                  "Summer",
                  "Autumn",
                  "Winter"
                ]
              },
              {
                "type": "string",
                "enum": [
                  "Spring",
                  "Summer",
                  "Autumn",
                  "Winter"
                ]
              }
            ],
            "type": "array",
            "maxItems": 2,
            "minItems": 2,
            "title": "Top 2 Seasons"
          },
          "scorecard": {
            "$ref": "#/components/schemas/Scorecard"
          },
          "reliability": {
            "$ref": "#/components/schemas/Reliability"
          },
          "result_state": {
            "type": "string",
            "enum": [
              "ok",
              "ok_low_reliability",
              "insufficient_photos",
              "no_face_detected",
              "multiple_subjects",
              "filter_suspected",
              "failed"
            ],
            "title": "Result State"
          },
          "trace": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Trace"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "top_2_seasons",
          "scorecard",
          "reliability",
          "result_state",
          "trace"
        ],
        "title": "AnalysisResult"
      },
      "AnalyzeRequest": {
        "properties": {
          "force_recompute": {
            "type": "boolean",
            "title": "Force Recompute",
            "default": false
          }
        },
        "type": "object",
        "title": "AnalyzeRequest"
      },
      "AnalyzeResponse": {
        "properties": {
          "accepted": {
            "type": "boolean",
            "title": "Accepted"
          }
        },
        "type": "object",
        "required": [
          "accepted"
        ],
        "title": "AnalyzeResponse"
      },
      "PhotoRegisterRequest": {
        "properties": {
          "filename": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Filename"
          },
          "mime_type": {
            "type": "string",
            "maxLength": 64,
            "minLength": 1,
            "title": "Mime Type"
          },
          "size_bytes": {
            "type": "integer",
            "maximum": 25000000.0,
            "exclusiveMinimum": 0.0,
            "title": "Size Bytes"
          }
        },
        "type": "object",
        "required": [
          "filename",
          "mime_type",
          "size_bytes"
        ],
        "title": "PhotoRegisterRequest"
      },
      "PhotoRegisterResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "accepted": {
            "type": "boolean",
            "title": "Accepted"
          },
          "reasons": {
            "items": {
              "type": "string",
              "enum": [
                "session_not_pending",
                "photo_limit_exceeded",
                "invalid_filename",
                "unsupported_mime_type"
              ]
            },
            "type": "array",
            "title": "Reasons"
          },
          "upload_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Upload Url"
          },
          "upload_fields": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Upload Fields"
          }
        },
        "type": "object",
        "required": [
          "id",
          "accepted",
          "reasons"
        ],
        "title": "PhotoRegisterResponse"
      },
      "ProblemDetail": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "status": {
            "type": "integer",
            "title": "Status"
          },
          "detail": {
            "type": "string",
            "title": "Detail"
          },
          "error_code": {
            "type": "string",
            "enum": [
              "invalid_session",
              "session_not_found",
              "session_deleted",
              "insufficient_photos",
              "already_running",
              "already_complete",
              "result_not_ready",
              "forbidden",
              "invalid_request",
              "internal_error",
              "rate_limit_exceeded"
            ],
            "title": "Error Code"
          }
        },
        "type": "object",
        "required": [
          "type",
          "title",
          "status",
          "detail",
